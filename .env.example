# ============================
# JClaw v2.1 Configuration
# ============================

# LINE Messaging API (Required)
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LLM Engine (Required — any Ollama-compatible model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
# Examples: qwen3:14b, qwen3:72b, llama4:scout, deepseek-r1:14b, gemma3:27b

# Server
PORT=3001

# Web Search — SearXNG (Optional, self-hosted, free & unlimited)
# docker compose up -d searxng
SEARXNG_URL=http://localhost:8899

# Memory System — memclawz (Optional, Tier S, self-hosted)
# Requires: Qdrant + Neo4j + memclawz API
# See: https://github.com/yoniassia/memclawz
MEMCLAWZ_URL=http://localhost:3500

# Owner Mode (Optional — restrict bot to single user)
OWNER_ONLY=false
OWNER_USER_ID=
# Use /setowner in LINE to set your userId

# Google Workspace (Optional — user configures own credentials)
# 1. Create OAuth client at https://console.cloud.google.com/apis/credentials
# 2. Enable Gmail, Calendar, Tasks, Drive APIs
# 3. Get refresh token via OAuth flow
# 4. Fill in below — JClaw auto-enables Gmail+Calendar+Tasks+Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# System Prompt (Optional — override default personality)
# SYSTEM_PROMPT=あなたは...

# ============================
# All ports above are configurable.
# You can swap any component:
#   - LLM: Ollama, vLLM, OpenAI-compatible API
#   - Search: SearXNG, or any JSON-returning search API
#   - Memory: memclawz, or disable for basic mode
#   - Google: Any Google account with OAuth credentials
# ============================
